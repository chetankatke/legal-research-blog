---
export interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description, lang = 'en' } = Astro.props;

const locales = [
  { code: 'en', label: 'English' },
  { code: 'mr', label: 'मराठी' },
  { code: 'hi', label: 'हिन्दी' },
  { code: 'ta', label: 'தமிழ்' },
  { code: 'bn', label: 'বাংলা' },
  { code: 'te', label: 'తెలుగు' },
  { code: 'kn', label: 'ಕನ್ನಡ' },
  { code: 'ml', label: 'മലയാളം' },
  { code: 'gu', label: 'ગુજરાતી' },
  { code: 'pa', label: 'ਪੰਜਾਬੀ' },
];
const path = Astro.url.pathname;
const base = path.startsWith(`/${lang}`) ? `/${lang}` : '';
const currentPath = path.replace(base, '') || '/';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description || title} />
  </head>
  <body>
    <nav>
      <a href={`/${lang}/`}>Home</a>
      <span style="margin-left: 1rem;">
        {locales.map(l => (
          <a
            href={`/${l.code}${currentPath === '/' ? '' : currentPath}`}
            style={{ marginRight: '0.5rem', fontWeight: l.code === lang ? 'bold' : 'normal' }}
          >{l.label}</a>
        ))}
      </span>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
