---
import { locales, siteConfig } from "@/site-config";
import { withBase } from "@/utils/path";

interface Props {
	lang?: string;
}

const { lang = "en" } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="left">
		<span>&copy; {year} {siteConfig.author}</span>
		{!siteConfig.hideThemeCredit && (
			<span class="theme-credit">
				🚀 Powered by <a href="https://github.com/AnjayGoel/astro-sienna" rel="noopener">Astro Sienna</a>
			</span>
		)}
	</div>
	<div class="right">
		<a href={withBase("/rss.xml")}>RSS</a>
	</div>
	<div class="lang-bar">
		{locales.map((loc, i) => (
			<>
				<a href={withBase(`/${loc.code}/`)} class:list={["lang-link", { active: loc.code === lang }]}>
					{loc.native}
				</a>
				{i < locales.length - 1 && <span class="lang-sep" aria-hidden="true">·</span>}
			</>
		))}
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--hairline);
		padding-top: 22px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 16px;
		font-family: var(--font-sans);
		font-size: 12.5px;
		color: hsl(var(--theme-text) / 0.72);
		transition: border-color 0.35s ease;
	}
	.site-footer .left {
		display: flex;
		gap: 18px;
		align-items: center;
		flex-wrap: wrap;
	}
	.site-footer .theme-credit {
		font-size: 11.5px;
		color: hsl(var(--theme-text) / 0.55);
	}
	.site-footer .theme-credit a {
		color: inherit;
		border-bottom: 1px dotted hsl(var(--theme-text) / 0.35);
	}
	.site-footer .theme-credit a:hover {
		color: hsl(var(--theme-accent));
		border-bottom-color: currentColor;
	}
	.site-footer a {
		color: hsl(var(--theme-text-muted));
		transition: color 0.2s ease;
	}
	.site-footer a:hover {
		color: hsl(var(--theme-accent));
	}

	/* Language bar across full width */
	.lang-bar {
		width: 100%;
		display: flex;
		align-items: center;
		gap: 6px;
		flex-wrap: wrap;
		padding-top: 14px;
		margin-top: 8px;
		border-top: 1px solid var(--hairline);
		font-size: 12px;
		color: hsl(var(--theme-text) / 0.5);
	}
	.lang-link {
		color: hsl(var(--theme-text-muted));
		text-decoration: none;
		padding: 2px 4px;
		border-radius: 3px;
		transition: color 0.2s ease, background-color 0.2s ease;
	}
	.lang-link:hover {
		color: hsl(var(--theme-accent));
		background: var(--accent-soft);
	}
	.lang-link.active {
		color: hsl(var(--theme-text));
		font-weight: 500;
	}
	.lang-sep {
		color: var(--faint);
		font-size: 10px;
	}

	@media (max-width: 420px) {
		.site-footer {
			font-size: 11.5px;
			gap: 12px;
		}
		.lang-bar {
			font-size: 11px;
			gap: 4px;
		}
	}
</style>
