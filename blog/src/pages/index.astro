---
import { siteConfig, locales } from "@/site-config";
import { withBase } from "@/utils/path";
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout meta={{ title: "Home", description: siteConfig.description }}>
	<section class="hero">
		<p>{siteConfig.description}</p>
	</section>

	<section class="lang-picker" aria-labelledby="lang-label">
		<div class="section-label" id="lang-label">Select language</div>
		<ul class="lang-list">
			{locales.map((loc) => (
				<li>
					<a data-astro-prefetch href={withBase(`/${loc.code}/`)}>
						<span class="lang-native">{loc.native}</span>
						<span class="lang-label">{loc.label}</span>
					</a>
				</li>
			))}
		</ul>
	</section>
</PageLayout>

<style>
	.hero {
		margin-bottom: 88px;
	}
	.hero p {
		font-size: 19.5px;
		line-height: 1.65;
		color: hsl(var(--theme-text));
		margin: 0 0 22px;
		max-width: 60ch;
		text-wrap: pretty;
		white-space: pre-line;
	}

	.lang-picker {
		margin-bottom: 96px;
	}

	.lang-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 12px;
	}
	.lang-list li {
		border: 1px solid var(--hairline);
		border-radius: 4px;
		transition: border-color 0.2s ease, background-color 0.2s ease;
	}
	.lang-list li:hover {
		border-color: hsl(var(--theme-accent));
		background: var(--accent-soft);
	}
	.lang-list a {
		display: block;
		padding: 16px 20px;
		text-decoration: none;
	}
	.lang-native {
		display: block;
		font-family: var(--font-serif);
		font-size: 18px;
		font-weight: 500;
		color: hsl(var(--theme-text));
		margin-bottom: 2px;
	}
	.lang-label {
		display: block;
		font-family: var(--font-sans);
		font-size: 12px;
		color: hsl(var(--theme-text) / 0.55);
	}
	.lang-list a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.hero { margin-bottom: 64px; }
		.hero p { font-size: 18px; }
		.lang-list { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
	}
	@media (max-width: 420px) {
		.hero { margin-bottom: 48px; }
		.hero p { font-size: 17px; }
		.lang-list { grid-template-columns: 1fr 1fr; gap: 8px; }
		.lang-list a { padding: 12px 16px; }
		.lang-native { font-size: 16px; }
	}
</style>
