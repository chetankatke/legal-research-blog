---
import { getAllPosts } from "@/data/post";
import PostLayout from "@/layouts/BlogPost.astro";
import { locales } from "@/site-config";
import { withBase } from "@/utils/path";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { render } from "astro:content";

export const getStaticPaths = (async () => {
	const blogEntries = await getAllPosts();
	const paths = blogEntries.flatMap((entry) => {
		const entryLang = entry.data.lang;
		const slug = entry.id.replace(/^[a-z]{2}\//, "");
		return locales
			.filter((loc) => loc.code === entryLang)
			.map((loc) => ({
				params: { lang: loc.code, slug },
				props: { entry },
			}));
	});
	return paths;
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { entry } = Astro.props;
const { lang } = Astro.params;

if (!entry || entry.data.lang !== lang) {
	return Astro.redirect(withBase(`/${lang}/`));
}

const { Content } = await render(entry);
---

<PostLayout post={entry}>
	<Content />
</PostLayout>
